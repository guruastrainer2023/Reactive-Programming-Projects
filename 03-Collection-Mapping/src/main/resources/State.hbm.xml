<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-5.0.dtd">
  
 <hibernate-mapping package="com.genpact.business"> 

	<class name="com.training.model.State" table="States">
		<id name="id">
				<generator class="native"></generator>
		</id>
		<property name="name"></property>
		<set name="cityNames" table="State_Cities">
			<key column="state_id"></key>
			<element column="city_name" type="java.lang.String"></element>
		</set>
	</class> 
  
            
 </hibernate-mapping>  