<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-5.0.dtd">

<hibernate-mapping>

	<class name="com.training.bean.pack4.Person" table="Persons20">

		<id name="personId" type="int">
			<generator class="assigned" />
		</id>

		<property name="personName"></property>
		<property name="dateOfBirth"></property>
		<property name="gender"></property>
		
		<many-to-one 
				name="contactInfo" 
				class="com.training.bean.pack4.ContactInfo" 
				cascade="all" 
				lazy="false" 
				unique="true" 
				not-null="false"></many-to-one>


	</class>

</hibernate-mapping>