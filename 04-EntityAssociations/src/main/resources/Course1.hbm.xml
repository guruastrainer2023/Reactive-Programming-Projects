<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://www.hibernate.org/dtd/hibernate-mapping-5.0.dtd">

<hibernate-mapping>
	
	<class name="com.training.bean.pack2.Course" table="courses10">
	
   		<id name="courseId">
   			<generator class="native"/>
  		</id>
  		
  		<property name="courseName"></property>
  		<property name="fee"></property>
  		
  		<set name="subjects" cascade="all">
  			<key column="course_id"></key>
  			<one-to-many class="com.zensar.training.bean.pack2.Subject"/>
  		</set>

	</class>
	
   	
</hibernate-mapping>